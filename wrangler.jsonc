{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "ghs-funnel-web",
  "main": "worker.js",
  "compatibility_date": "2025-09-27",
  "compatibility_flags": ["nodejs_compat"],
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": ".",
    "binding": "ASSETS"
  },
  "r2_buckets": [
    {
      "binding": "MEDIA",
      "bucket_name": "ghs-media"
    }
  ]
}
